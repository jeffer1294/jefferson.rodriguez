---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "./ProjectCard.astro";
import { getCollection } from "astro:content";
import { categories } from "../data/site";

interface Props {
  category: "research" | "policy" | "innovation";
}
const { category } = Astro.props;
const meta = categories[category];
const projects = (await getCollection("projects"))
  .filter((p) => p.data.category === category)
  .sort((a, b) => a.data.order - b.data.order);

const others = (["research", "policy", "innovation"] as const).filter(
  (c) => c !== category
);
---

<BaseLayout title={meta.label} description={meta.blurb}>
  <section class="wrap chead">
    <p class="eyebrow">Projects · {String(projects.length).padStart(2, "0")}</p>
    <h1 class="chead-title"><span class="accent-it">{meta.label}</span></h1>
    <p class="chead-blurb measure">{meta.blurb}</p>
  </section>

  <section class="wrap cgrid">
    {projects.map((p, i) => (
      <ProjectCard
        href={`/projects/${p.id}/`}
        index={String(i + 1).padStart(2, "0")}
        title={p.data.title}
        org={p.data.org}
        period={p.data.period}
        summary={p.data.summary}
        methods={p.data.methods}
        cover={p.data.cover}
      />
    ))}
  </section>

  <section class="wrap cswitch">
    <hr class="rule" />
    <div class="cswitch-row">
      <span class="eyebrow">Keep exploring</span>
      <div class="cswitch-links">
        {others.map((c) => (
          <a class="btn" href={`/projects/${c}/`}>{categories[c].label} →</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .chead { padding-top: clamp(2.5rem, 1.5rem + 4vw, 5rem); }
  .chead-title { font-size: var(--step-4); margin: 0.25em 0 0.3em; }
  .chead-title .accent-it { font-size: 1em; }
  .chead-blurb { font-size: var(--step-1); color: var(--ink-soft); }
  .cgrid { margin-top: 2.5rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  .cswitch { margin-top: var(--section-y); }
  .cswitch-row { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; padding-top: 2rem; }
  .cswitch-links { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  @media (max-width: 900px) { .cgrid { grid-template-columns: 1fr; } }
  @media (min-width: 901px) and (max-width: 1100px) { .cgrid { grid-template-columns: repeat(2, 1fr); } }
</style>
