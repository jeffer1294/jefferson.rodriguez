---
import "../styles/global.css";
import { site } from "../data/site";
import Contours from "../components/Contours.astro";
import { getCollection } from "astro:content";

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : site.name;
const desc = description ?? site.tagline;

const all = await getCollection("projects");
const count = (c: string) =>
  String(all.filter((p) => p.data.category === c).length).padStart(2, "0");

const projectLinks = [
  { label: "Research", href: "/projects/research/", count: count("research") },
  { label: "Policy", href: "/projects/policy/", count: count("policy") },
  { label: "Innovation", href: "/projects/innovation/", count: count("innovation") },
];

const navAfter = [
  { label: "Teaching", href: "/teaching/" },
  { label: "Publications", href: "/publications/" },
  { label: "Beyond", href: "/beyond/" },
  { label: "Contact", href: "/contact/" },
];
const path = Astro.url.pathname;
const inProjects = path.startsWith("/projects");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>

    <header class="site-head">
      <div class="wrap head-inner">
        <a href="/" class="brand">
          <span class="brand-mark">JRN</span>
          <span class="brand-name">{site.name}</span>
        </a>
        <button class="nav-toggle mono" aria-expanded="false" aria-controls="nav">Menu</button>
        <nav id="nav" class="nav">
          <a href="/about/" class={`nav-link ${path === "/about/" ? "is-active" : ""}`}>My story</a>

          <div class={`nav-drop ${inProjects ? "is-active" : ""}`}>
            <button
              class="nav-link drop-btn"
              aria-expanded="false"
              aria-haspopup="true"
              aria-controls="projects-menu"
            >
              Projects <span class="chev" aria-hidden="true">▾</span>
            </button>
            <div class="drop-panel" id="projects-menu">
              {projectLinks.map((l) => (
                <a href={l.href} class={`drop-link ${path === l.href ? "is-here" : ""}`}>
                  <span>{l.label}</span>
                  <span class="drop-count mono">{l.count}</span>
                </a>
              ))}
            </div>
          </div>

          {navAfter.map((n) => (
            <a href={n.href} class={`nav-link ${path === n.href ? "is-active" : ""}`}>
              {n.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot band">
      <div class="foot-contours"><Contours /></div>
      <div class="wrap foot-inner">
        <div>
          <p class="foot-name">{site.name}</p>
          <p class="foot-tag measure">{site.tagline}</p>
        </div>
        <div class="foot-links mono">
          <a href={`mailto:${site.email}`}>Email</a>
          <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={site.cv} target="_blank" rel="noopener">CV (PDF)</a>
          <a href={site.cvExtended} target="_blank" rel="noopener">Extended CV (PDF)</a>
        </div>
      </div>
      <div class="wrap foot-base mono">
        <span>© {new Date().getFullYear()} {site.name}</span>
      </div>
    </footer>

    <style>
      .skip {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--accent);
        color: var(--accent-ink);
        padding: 0.6em 1em;
        z-index: 100;
      }
      .skip:focus { left: 1rem; top: 1rem; }

      .site-head {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 90%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .head-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-block: 0.75rem;
      }
      .brand { display: inline-flex; align-items: center; gap: 0.8rem; }
      .brand-mark {
        border: 1.5px solid var(--ink);
        border-radius: var(--arch);
        padding: 0.55em 0.6em 0.35em;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        line-height: 1;
        transition: border-color var(--transition), color var(--transition);
      }
      .brand:hover .brand-mark { border-color: var(--accent); color: var(--accent); }
      .brand-name {
        font-weight: 500;
        font-size: 0.9rem;
        letter-spacing: 0.01em;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: clamp(0.9rem, 0.4rem + 1.4vw, 1.9rem);
      }
      .nav-link {
        font-family: var(--font-body);
        font-weight: 500;
        font-size: 0.78rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-soft);
        padding-block: 0.4em;
        background: transparent;
        border: 0;
        cursor: pointer;
        transition: color var(--transition);
      }
      .nav-link:hover { color: var(--ink); }
      .nav-link.is-active { color: var(--accent); }
      .nav-drop.is-active .drop-btn { color: var(--accent); }
      .chev { font-size: 0.85em; }

      .nav-drop { position: relative; }
      .drop-panel {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        min-width: 13.5rem;
        border-top: 0.6rem solid transparent;
        background: var(--green);
        background-clip: padding-box;
        color: var(--green-ink);
        padding: 0.5rem 1.1rem 0.7rem;
        border-radius: 0 0 18px 0;
        z-index: 60;
      }
      .nav-drop.is-open .drop-panel { display: block; }
      @media (hover: hover) and (min-width: 821px) {
        .nav-drop:hover .drop-panel,
        .nav-drop:focus-within .drop-panel { display: block; }
      }
      .drop-link {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1.5rem;
        padding: 0.6em 0;
        font-size: 0.88rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        color: var(--green-ink);
        border-top: 1px solid var(--green-line);
        transition: color var(--transition);
      }
      .drop-link:first-child { border-top: 0; }
      .drop-link:hover, .drop-link.is-here { color: var(--accent-soft); }
      .drop-count { font-size: 0.72rem; color: var(--accent-soft); }

      .nav-toggle {
        display: none;
        background: transparent;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--ink);
        padding: 0.45em 1em;
        font-size: var(--step--1);
        letter-spacing: 0.04em;
        cursor: pointer;
      }

      .site-foot {
        position: relative;
        overflow: hidden;
        margin-top: var(--section-y);
        padding-top: var(--section-y);
      }
      .foot-contours {
        position: absolute;
        right: -70px;
        top: -50px;
        width: 340px;
        color: var(--accent-soft);
        opacity: 0.35;
        pointer-events: none;
        z-index: 0;
      }
      .foot-inner {
        position: relative;
        display: flex;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
        padding-bottom: 2.5rem;
      }
      .foot-name { font-weight: 600; font-size: var(--step-1); margin: 0 0 0.4em; letter-spacing: -0.01em; }
      .foot-tag { color: var(--green-soft); margin: 0; }
      .foot-links { display: flex; flex-direction: column; gap: 0.6em; font-size: var(--step--1); }
      .foot-links a { color: var(--green-soft); transition: color var(--transition); }
      .foot-links a:hover { color: var(--accent-soft); }
      .foot-base {
        position: relative;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding-block: 1.6rem;
        border-top: 1px solid var(--green-line);
        font-size: var(--step--1);
        color: var(--green-soft);
        letter-spacing: 0.04em;
      }

      @media (max-width: 960px) {
        .brand-name { display: none; }
      }
      @media (max-width: 820px) {
        .nav-toggle { display: inline-block; }
        .nav {
          display: none;
          position: absolute;
          left: 0;
          right: 0;
          top: 100%;
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          background: var(--surface);
          border-bottom: 1px solid var(--line);
          padding: 0.5rem 0 0.8rem;
        }
        .nav.is-open { display: flex; }
        .nav-link {
          width: 100%;
          text-align: left;
          padding: 0.8em clamp(1.1rem, 0.6rem + 2.5vw, 2.5rem);
        }
        .nav-drop { position: static; }
        .drop-btn { display: flex; justify-content: space-between; align-items: center; }
        .drop-panel {
          position: static;
          transform: none;
          min-width: 0;
          border-top: 0;
          border-radius: 0;
          background: transparent;
          color: inherit;
          padding: 0 clamp(1.1rem, 0.6rem + 2.5vw, 2.5rem) 0.4rem;
        }
        .drop-link {
          color: var(--ink-soft);
          border-top: 0;
          padding: 0.55em 0 0.55em 1.1rem;
          border-left: 1px solid var(--line);
        }
        .drop-link:hover, .drop-link.is-here { color: var(--accent); }
        .drop-count { color: var(--accent); }
        .head-inner { position: relative; }
      }
    </style>

    <script>
      const t = document.querySelector(".nav-toggle");
      const n = document.getElementById("nav");
      t?.addEventListener("click", () => {
        const open = n?.classList.toggle("is-open");
        t.setAttribute("aria-expanded", String(!!open));
      });

      document.querySelectorAll(".nav-drop").forEach((drop) => {
        const btn = drop.querySelector(".drop-btn");
        btn?.addEventListener("click", () => {
          const open = drop.classList.toggle("is-open");
          btn.setAttribute("aria-expanded", String(open));
        });
      });
      document.addEventListener("click", (e) => {
        document.querySelectorAll(".nav-drop.is-open").forEach((drop) => {
          if (!drop.contains(e.target as Node)) {
            drop.classList.remove("is-open");
            drop.querySelector(".drop-btn")?.setAttribute("aria-expanded", "false");
          }
        });
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          document.querySelectorAll(".nav-drop.is-open").forEach((drop) => {
            drop.classList.remove("is-open");
            drop.querySelector(".drop-btn")?.setAttribute("aria-expanded", "false");
          });
        }
      });
    </script>
  </body>
</html>
