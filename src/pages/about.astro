---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, about, highlights } from "../data/site";
---

<BaseLayout title="My Story" description="About Jefferson Rodriguez-Najera">
  <section class="wrap ahead">
    <p class="eyebrow">My story</p>
    <h1 class="ahead-title measure">From implementation to building <span class="accent-it">evidence</span>.</h1>
  </section>

  <section class="wrap abody">
    <div class="aside">
      <div class="arch-frame">
        <div class="arch-media aphoto">
          <img src={site.photoAbout ?? site.photo} alt={site.name} onerror="this.style.display='none';this.parentElement.classList.add('noimg')" />
          <span class="photo-fallback mono">Your photo here</span>
        </div>
      </div>
      <ul class="afacts mono">
        {highlights.map((h) => <li>{h}</li>)}
      </ul>
      <div class="acta">
        <a class="btn btn--solid" href={site.cv} target="_blank" rel="noopener">Download CV</a>
        <a class="btn" href={site.cvExtended} target="_blank" rel="noopener">Extended CV</a>
        <a class="btn" href="/contact/">Get in touch</a>
      </div>
    </div>
    <div class="acopy measure">
      {about.map((para) => <p>{para}</p>)}
    </div>
  </section>
</BaseLayout>

<style>
  .ahead { padding-top: clamp(2.5rem, 1.5rem + 4vw, 5rem); }
  .ahead-title { font-size: var(--step-3); margin-top: 0.4em; }
  .abody {
    margin-top: var(--section-y);
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: clamp(2rem, 1rem + 4vw, 5rem);
    align-items: start;
  }
  .aside { position: sticky; top: 6rem; display: flex; flex-direction: column; gap: 1.4rem; }
  .aphoto { aspect-ratio: 0.72; }
  .photo-fallback { position: absolute; inset: 0; display: none; align-items: center; justify-content: center; color: var(--ink-faint); font-size: var(--step--1); letter-spacing: 0.1em; }
  .aphoto.noimg .photo-fallback { display: flex; }
  .afacts li::before { border-radius: 50%; }
  .afacts { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: var(--step--1); }
  .afacts li { color: var(--ink-soft); padding-left: 1em; position: relative; }
  .afacts li::before { content: ""; position: absolute; left: 0; top: 0.6em; width: 5px; height: 5px; background: var(--accent); }
  .acta { display: flex; flex-direction: column; gap: 0.6rem; }
  .acopy p { margin: 0 0 1.4em; color: var(--ink-soft); font-size: var(--step-0); line-height: 1.75; }
  .acopy p:first-child { color: var(--ink); font-size: clamp(1.1rem, 1.02rem + 0.35vw, 1.24rem); line-height: 1.65; }
  @media (max-width: 820px) {
    .abody { grid-template-columns: 1fr; }
    .aside { position: static; max-width: 320px; }
  }
</style>
