---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Contours from "../components/Contours.astro";
import { getCollection } from "astro:content";
import { site, highlights, categories, events } from "../data/site";

const all = await getCollection("projects");
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const counts = {
  research: all.filter((p) => p.data.category === "research").length,
  policy: all.filter((p) => p.data.category === "policy").length,
  innovation: all.filter((p) => p.data.category === "innovation").length,
};
const catKeys = ["research", "policy", "innovation"] as const;

// Events with images for the home marquee. Duplicated in the template so the
// track can loop seamlessly.
const marquee = events.filter((e) => e.image);
---

<BaseLayout>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <h1 class="hero-title">Pura vida! I’m <span class="accent-it">Jefferson</span></h1>
        <p class="hero-tag measure">I grew up in the mountains outside San José, Costa Rica, and I've spent my career trying to bring good policy back to towns like the one I grew up in.</p>
        <div class="hero-actions">
          <a class="btn btn--solid" href="/about/">My story</a>
          <a class="btn" href="/projects/research/">Explore projects</a>
          <a class="btn" href="/contact/">Ways to work together →</a>
        </div>
        <div class="hero-soc mono">
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>
          <a href={site.cv} target="_blank" rel="noopener">CV (PDF) ↓</a>
        </div>
      </div>
      <div class="hero-photo-col">
        <div class="arch-frame hero-photo">
          <div class="arch-media hero-media">
            <img src={site.photo} alt={site.name} onerror="this.style.display='none';this.parentElement.classList.add('noimg')" />
            <span class="photo-fallback mono">Photo</span>
          </div>
        </div>
        <p class="hero-caption mono">Vázquez de Coronado, Costa Rica</p>
      </div>
    </div>
  </section>

  <section class="strip">
    <div class="wrap strip-inner mono">
      {highlights.map((h) => <span class="strip-item">{h}</span>)}
    </div>
  </section>

  <section class="band cats-band">
    <div class="band-contours"><Contours /></div>
    <div class="wrap band-inner">
      <p class="eyebrow eyebrow--band">Three kinds of work</p>
      <h2 class="band-title">One question behind all of it: <span class="accent-it accent-it--band">what actually works?</span></h2>
      <div class="cats">
        {catKeys.map((k, i) => (
          <a class="cat" href={`/projects/${k}/`}>
            <span class="cat-num mono">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="cat-name">{categories[k].label}</h3>
            <p class="cat-blurb">{categories[k].blurb}</p>
            <span class="cat-cta mono">{counts[k]} projects →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="wrap block">
    <div class="block-head">
      <p class="eyebrow">Selected work</p>
      <h2 class="block-title">Featured projects</h2>
    </div>
    <div class="grid-3">
      {featured.map((p) => (
        <ProjectCard
          href={`/projects/${p.id}/`}
          title={p.data.title}
          org={p.data.org}
          period={p.data.period}
          summary={p.data.summary}
          methods={p.data.methods}
          cover={p.data.cover}
        />
      ))}
    </div>
  </section>

  <section class="events-band">
    <div class="wrap events-head">
      <div>
        <p class="eyebrow">On the record</p>
        <h2 class="block-title">Events &amp; talks</h2>
      </div>
      <a class="btn" href="/beyond/#talks">See all →</a>
    </div>
    <div class="marquee" aria-label="Recent events and talks">
      <div class="marquee-track">
        {[...marquee, ...marquee].map((e, i) => (
          <a
            class="mq-card"
            href="/beyond/#talks"
            aria-hidden={i >= marquee.length ? "true" : undefined}
            tabindex={i >= marquee.length ? -1 : undefined}
          >
            <div class="mq-media">
              <img src={e.image} alt={e.title} loading="lazy" />
            </div>
            <div class="mq-body">
              <span class="mq-date mono">{e.date} · {e.type}</span>
              <h3 class="mq-title">{e.title}</h3>
              <p class="mq-event">{e.event}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero { padding-block: clamp(2.5rem, 1.5rem + 4vw, 5rem); overflow: hidden; }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.3fr auto;
    gap: clamp(1.5rem, 1rem + 3vw, 4rem);
    align-items: center;
    padding-right: clamp(2.5rem, 2rem + 2vw, 4rem);
  }
  .hero-copy { min-width: 0; position: relative; z-index: 2; }
  .hero-title { font-size: var(--step-4); margin: 0.35em 0 0.3em; }
  .hero-tag { font-size: var(--step-1); font-weight: 400; color: var(--ink-soft); line-height: 1.45; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.8rem; }
  .hero-soc { display: flex; flex-wrap: wrap; gap: 1.4rem; margin-top: 1.5rem; font-size: var(--step--1); }
  .hero-soc a { color: var(--ink-faint); transition: color var(--transition); }
  .hero-soc a:hover { color: var(--accent); }

  .hero-photo-col { position: relative; justify-self: end; }
  .hero-photo { position: relative; z-index: 1; width: clamp(220px, 24vw, 290px); }
  .hero-media { aspect-ratio: 0.72; }
  .photo-fallback { position: absolute; inset: 0; display: none; align-items: center; justify-content: center; color: var(--ink-faint); font-size: var(--step--1); letter-spacing: 0.1em; }
  .hero-media.noimg .photo-fallback { display: flex; }
  .hero-caption {
    position: relative;
    z-index: 1;
    text-align: center;
    font-size: var(--step--1);
    color: var(--ink-faint);
    margin: 0.8rem 0 0;
  }
  .strip { border-block: 1px solid var(--line); background: var(--bg-2); }
  .strip-inner {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 0.5rem + 2vw, 2.5rem);
    padding-block: 1.1rem;
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .strip-item { display: inline-flex; align-items: center; gap: 0.8em; }
  .strip-item:not(:last-child)::after { content: ""; width: 5px; height: 5px; background: var(--accent); border-radius: 50%; }

  .cats-band {
    position: relative;
    overflow: hidden;
    margin-top: var(--section-y);
    padding-block: clamp(2.8rem, 2rem + 3vw, 5rem);
  }
  .band-contours {
    position: absolute;
    left: -90px;
    bottom: -110px;
    width: 360px;
    color: var(--accent-soft);
    opacity: 0.3;
    pointer-events: none;
  }
  .band-inner { position: relative; }
  .band-title { font-size: var(--step-2); margin-top: 0.5em; max-width: 26ch; }
  .cats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.4rem, 1rem + 2vw, 3rem);
    margin-top: 2.4rem;
  }
  .cat {
    border-top: 1px solid var(--green-line);
    padding-top: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    transition: border-color var(--transition);
  }
  .cat:hover { border-color: var(--accent-soft); }
  .cat-num { font-size: var(--step--1); color: var(--accent-soft); letter-spacing: 0.1em; }
  .cat-name { font-size: var(--step-1); color: var(--green-ink); }
  .cat-blurb { color: var(--green-soft); margin: 0; font-size: var(--step--1); line-height: 1.55; }
  .cat-cta { margin-top: auto; padding-top: 0.5rem; color: var(--accent-soft); font-size: var(--step--1); }

  .block { padding-top: var(--section-y); }
  .block-head { margin-bottom: 2rem; }
  .block-title { font-size: var(--step-2); margin-top: 0.3em; }

  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.4rem, 1rem + 1.5vw, 2.4rem); }

  .events-band { margin-top: var(--section-y); padding-block: clamp(2.5rem, 2rem + 2vw, 4rem); overflow: hidden; }
  .events-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.2rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .marquee {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-x;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .marquee::-webkit-scrollbar { display: none; }
  .marquee.is-dragging { cursor: grabbing; }
  .marquee.is-dragging .mq-card { pointer-events: none; }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 1.4rem;
    padding: 4px 0;
  }

  .mq-card {
    flex: 0 0 clamp(240px, 26vw, 320px);
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-2);
    transition: border-color var(--transition), transform var(--transition);
  }
  .mq-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .mq-media { aspect-ratio: 16 / 10; overflow: hidden; background: var(--surface); }
  .mq-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mq-body { padding: 1rem 1.1rem 1.2rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .mq-date { font-size: var(--step--1); color: var(--accent); letter-spacing: 0.06em; text-transform: capitalize; }
  .mq-title { font-size: var(--step-0); line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .mq-event { font-size: var(--step--1); font-weight: 500; color: var(--accent-2); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  @media (max-width: 760px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.2rem; padding-right: 0; }
    .hero-photo-col { order: -1; justify-self: start; }
    .hero-photo { width: min(64vw, 250px); }
    .hero-caption { text-align: left; }
    .cats, .grid-3 { grid-template-columns: 1fr; }
  }
</style>

<script>
  const marquee = document.querySelector<HTMLElement>(".marquee");
  const track = marquee?.querySelector<HTMLElement>(".marquee-track");
  if (marquee && track) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // One "copy" of the duplicated card list — the seamless loop distance.
    const gap = () => parseFloat(getComputedStyle(track).columnGap || "0") || 0;
    let loopDist = (track.scrollWidth + gap()) / 2;
    const recompute = () => { loopDist = (track.scrollWidth + gap()) / 2; };
    window.addEventListener("resize", recompute);
    window.addEventListener("load", recompute);

    let paused = false;
    let dragging = false;
    let lastX = 0;
    let moved = 0;
    // Float accumulator — scrollLeft is rounded to an integer by the browser,
    // so a sub-pixel speed must be tracked separately or it never advances.
    let pos = marquee.scrollLeft;

    const wrap = () => {
      if (marquee.scrollLeft >= loopDist) marquee.scrollLeft -= loopDist;
      else if (marquee.scrollLeft < 0) marquee.scrollLeft += loopDist;
    };

    // Gentle auto-scroll that yields to the user.
    const SPEED = 0.4; // px per frame (~24px/s)
    const tick = () => {
      if (paused || dragging) {
        pos = marquee.scrollLeft; // stay in sync with manual scrolling
      } else {
        pos += SPEED;
        if (pos >= loopDist) pos -= loopDist;
        else if (pos < 0) pos += loopDist;
        marquee.scrollLeft = pos;
      }
      requestAnimationFrame(tick);
    };
    if (!reduce) requestAnimationFrame(tick);

    // Pause while the user reads or focuses a card.
    marquee.addEventListener("pointerenter", (e) => { if (e.pointerType === "mouse") paused = true; });
    marquee.addEventListener("pointerleave", (e) => { if (e.pointerType === "mouse") paused = false; });
    marquee.addEventListener("focusin", () => { paused = true; });
    marquee.addEventListener("focusout", () => { paused = false; });

    // Mouse drag-to-scroll (touch and trackpad use native scrolling).
    marquee.addEventListener("pointerdown", (e) => {
      paused = true;
      if (e.pointerType !== "mouse" || e.button !== 0) return;
      dragging = true; lastX = e.clientX; moved = 0;
      marquee.classList.add("is-dragging");
      marquee.setPointerCapture(e.pointerId);
    });
    marquee.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - lastX;
      lastX = e.clientX;
      moved += Math.abs(dx);
      marquee.scrollLeft -= dx;
      wrap();
    });
    const endDrag = (e: PointerEvent) => {
      if (dragging) {
        dragging = false;
        marquee.classList.remove("is-dragging");
      }
      if (e.pointerType !== "mouse" || !marquee.matches(":hover")) paused = false;
    };
    marquee.addEventListener("pointerup", endDrag);
    marquee.addEventListener("pointercancel", endDrag);

    // Suppress navigation when the pointer was dragged, not clicked.
    marquee.querySelectorAll<HTMLAnchorElement>(".mq-card").forEach((card) => {
      card.addEventListener("click", (e) => { if (moved > 6) e.preventDefault(); });
    });
  }
</script>
