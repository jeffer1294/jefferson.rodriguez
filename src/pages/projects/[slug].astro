---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { categories } from "../../data/site";

export async function getStaticPaths() {
  const reserved = new Set(["research", "policy", "innovation"]);
  const projects = await getCollection("projects");
  return projects
    .filter((p) => !reserved.has(p.id))
    .map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const { Content } = await render(p);
const cat = categories[p.data.category];

const siblings = (await getCollection("projects"))
  .filter((x) => x.data.category === p.data.category)
  .sort((a, b) => a.data.order - b.data.order);
const idx = siblings.findIndex((x) => x.id === p.id);
const prev = siblings[idx - 1];
const next = siblings[idx + 1];
---

<BaseLayout title={p.data.title} description={p.data.summary}>
  <article>
    <div class="wrap proj-head">
      <a class="back mono" href={`/projects/${p.data.category}/`}>← {cat.label}</a>
      <p class="eyebrow">{cat.label} · {p.data.period}</p>
      <h1 class="proj-title measure">{p.data.title}</h1>
      <p class="proj-summary measure">{p.data.summary}</p>
    </div>

    {p.data.cover && (
      <div class="wrap proj-cover">
        <img src={p.data.cover} alt="" />
      </div>
    )}

    <div class="wrap proj-grid">
      <aside class="meta">
        <dl>
          <dt class="mono">Role</dt>
          <dd>{p.data.role}</dd>
          <dt class="mono">Organization</dt>
          <dd>{p.data.org}</dd>
          <dt class="mono">Period</dt>
          <dd>{p.data.period}</dd>
          {p.data.location && (<><dt class="mono">Location</dt><dd>{p.data.location}</dd></>)}
        </dl>
        {p.data.methods.length > 0 && (
          <div class="meta-tags">
            <p class="mono meta-label">Methods &amp; tools</p>
            <ul>{p.data.methods.map((m) => <li>{m}</li>)}</ul>
          </div>
        )}
      </aside>

      <div class="prose measure">
        {p.data.links.length > 0 && (
          <div class="proj-cta">
            {p.data.links.map((l, i) => {
              const isDownload =
                /\.(pdf|docx?|pptx?|xlsx?|zip)(\?|#|$)/i.test(l.url) ||
                /sharepoint|drive\.google|dropbox/i.test(l.url);
              const isInternal = l.url.startsWith("/") && !isDownload;
              const arrow = isDownload ? "↓" : isInternal ? "→" : "↗";
              const attrs = isInternal
                ? {}
                : { target: "_blank", rel: "noopener" };
              return (
                <a class={i === 0 ? "btn btn--solid" : "btn"} href={l.url} {...attrs}>
                  {l.label} {arrow}
                </a>
              );
            })}
          </div>
        )}
        <Content />
        {p.data.embed && (
          <div class="embed-wrap">
            <iframe
              src={p.data.embed}
              title={p.data.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            />
          </div>
        )}

        {p.data.gallery.length > 0 && (
          <div class="proj-gallery">
            <p class="mono gallery-label">Gallery</p>
            <div class="gallery-grid">
              {p.data.gallery.map((g) => (
                <figure class="gallery-item">
                  <img src={g.src} alt={g.caption ?? ""} loading="lazy" />
                  {g.caption && <figcaption>{g.caption}</figcaption>}
                </figure>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <nav class="wrap proj-nav">
      <hr class="rule" />
      <div class="proj-nav-row">
        {prev ? (
          <a class="pn" href={`/projects/${prev.id}/`}>
            <span class="mono pn-dir">← Previous</span>
            <span class="pn-title">{prev.data.title}</span>
          </a>
        ) : <span></span>}
        {next ? (
          <a class="pn pn-r" href={`/projects/${next.id}/`}>
            <span class="mono pn-dir">Next →</span>
            <span class="pn-title">{next.data.title}</span>
          </a>
        ) : <span></span>}
      </div>
    </nav>
  </article>
</BaseLayout>

<style>
  .proj-head { padding-top: clamp(2rem, 1.5rem + 3vw, 4rem); }
  .back { color: var(--ink-faint); font-size: var(--step--1); transition: color var(--transition); }
  .back:hover { color: var(--accent); }
  .proj-head .eyebrow { margin-top: 1.4rem; }
  .proj-title { font-size: var(--step-3); margin: 0.4em 0; }
  .proj-summary { font-size: var(--step-1); color: var(--ink-soft); }
  .proj-cover { margin-top: 2rem; }
  .proj-cover img { width: 100%; border-radius: var(--r-card); display: block; }
  .proj-grid { margin-top: var(--section-y); display: grid; grid-template-columns: 280px 1fr; gap: clamp(2rem, 1rem + 4vw, 5rem); align-items: start; }
  .meta dl { display: grid; grid-template-columns: 1fr; gap: 0.15rem 0; margin: 0; }
  .meta dt { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin-top: 1.1rem; }
  .meta dd { margin: 0; color: var(--ink); }
  .meta dd:first-of-type { margin-top: 0; }
  .meta-label { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin: 1.6rem 0 0.6rem; }
  .meta-tags ul { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .meta-tags li { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-soft); border: 1px solid var(--line); border-radius: 999px; padding: 0.3em 0.8em; }
  .meta-links { display: flex; flex-direction: column; gap: 0.4rem; }
  .meta-links a { color: var(--accent-2); font-size: var(--step--1); }
  .prose :global(p) { margin: 0 0 1.3em; color: var(--ink-soft); font-size: var(--step-0); line-height: 1.7; }
  .prose :global(p:first-child) { color: var(--ink); font-size: var(--step-1); line-height: 1.6; }
  .prose :global(em) { color: var(--ink); font-style: italic; }
  .proj-gallery { margin-top: 2.5rem; }
  .gallery-label { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin: 0 0 0.9rem; }
  .gallery-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap); }
  .gallery-item { margin: 0; }
  .gallery-item img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 12px; display: block; }
  .gallery-item figcaption { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); margin-top: 0.5rem; line-height: 1.4; }
  @media (max-width: 560px) { .gallery-grid { grid-template-columns: 1fr; } }
  .proj-nav { margin-top: var(--section-y); }
  .proj-nav-row { display: flex; justify-content: space-between; gap: 2rem; padding-top: 2rem; }
  .pn { display: flex; flex-direction: column; gap: 0.4rem; max-width: 45%; transition: color var(--transition); }
  .pn-r { text-align: right; }
  .pn-dir { font-size: var(--step--1); color: var(--accent); }
  .pn-title { font-family: var(--font-display); font-weight: 600; letter-spacing: -0.01em; font-size: var(--step-1); color: var(--ink); }
  .pn:hover .pn-title { color: var(--accent); }
  @media (max-width: 820px) {
    .proj-grid { grid-template-columns: 1fr; }
    .pn { max-width: 100%; }
  }
</style>
